# 复制本文件为 .env 后再启动。演示模式不需要任何密钥。

# demo 表示使用内置演示数据；real 表示尝试真实数据 Provider。
APP_MODE=demo
APP_TIMEZONE=Asia/Shanghai
APP_PASSWORD=change-me

# 本地默认使用 SQLite，Docker Compose 示例中会覆盖为 PostgreSQL。
DATABASE_URL=sqlite:///work/data/ashare_replay.sqlite3
REPORT_OUTPUT_DIR=outputs/reports
CONFIG_PATH=configs/default_config.json
LOG_LEVEL=INFO

# 真实数据 Provider。默认 akshare 为免费公开数据源，不需要密钥；tushare 为可选权限型数据源。
REAL_PROVIDER=akshare
TUSHARE_TOKEN=

# 可选的大语言模型总结接口。未填写时系统使用确定性中文模板。
LLM_ENABLED=false
LLM_PROVIDER=
LLM_API_KEY=

# Web 服务地址。
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501
